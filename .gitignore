# 忽略 runs 文件夹及其所有子内容 (权重、日志、图片等)
runs/

# 同时也建议忽略以下常见的大文件或敏感文件
__pycache__/
*.pt          # 模型权重文件
*.pth         # PyTorch 模型文件
.idea/        # JetBrains IDE 配置
.vscode/      # VS Code 配置
*.csv         # 训练结果数据(可选，视情况而定)
*.png         # 训练过程中生成的图片(可选，视情况而定)
*.log         # 训练日志文件(可选，视情况而定)
*.zip         # 压缩文件(如模型压缩包等)
*.tar.gz      # 压缩文件(如模型压缩包等)
*.h5          # Keras 模型文件
*.ckpt        # TensorFlow 模型检查点文件